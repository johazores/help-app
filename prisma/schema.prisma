// Sagip data model.
// Design note: Stellar account secrets are never stored in plaintext — each
// StellarAccount keeps an AES-256-GCM ciphertext plus its iv/tag. Network config
// and other credentials live in the Setting table, not in code (per brief).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A person who signs in to Sagip. Custodial: we hold their Stellar keys for them.
model User {
  id        String   @id @default(cuid())
  phone     String   @unique
  name      String
  pinHash          String
  email            String?   @unique
  emailVerifiedAt  DateTime?
  avatar           String? // small data-URL image, resized client-side
  activeWalletId   String? // which wallet money actions use
  createdAt        DateTime  @default(now())

  wallets    Wallet[]
  recipients Recipient[]
  safetyNets SafetyNet[]
  sessions   UserSession[]
  codes      VerificationCode[]
}

/// A signed-in device. Tokens carry the session id; revoking kills the token.
model UserSession {
  id         String    @id @default(cuid())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  device     String
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?

  @@index([userId])
}

/// Root admins: entirely separate identity, credentials, and sessions.
model AdminUser {
  id           String         @id @default(cuid())
  username     String         @unique
  email        String         @unique
  name         String
  passwordHash String
  createdAt    DateTime       @default(now())
  sessions     AdminSession[]
}

model AdminSession {
  id         String    @id @default(cuid())
  admin      AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  adminId    String
  device     String
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?

  @@index([adminId])
}

/// One-time codes for email verification and PIN recovery.
model VerificationCode {
  id         String    @id @default(cuid())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  identifier String // the email the code was sent to
  codeHash   String
  purpose    String // EMAIL_VERIFY | PIN_RESET
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?

  @@index([userId, purpose])
}

/// A custodial Stellar account. Secret is encrypted at rest.
model StellarAccount {
  id              String   @id @default(cuid())
  publicKey       String   @unique
  encryptedSecret String
  encryptionIv    String
  encryptionTag   String
  createdAt       DateTime @default(now())

  wallet    Wallet?
  recipient Recipient? @relation("RecipientAccount")
}

/// A named wallet a person owns. Custodial: keys live in StellarAccount,
/// encrypted. "Imported" wallets were brought in by the user's own secret key.
model Wallet {
  id        String   @id @default(cuid())
  name      String
  imported  Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  stellarAccount   StellarAccount @relation(fields: [stellarAccountId], references: [id])
  stellarAccountId String         @unique

  safetyNets SafetyNet[]

  @@index([userId])
}

/// A loved one the money can open to. Also custodial, so they can receive
/// without ever managing keys.
model Recipient {
  id           String   @id @default(cuid())
  name         String
  relationship String
  phone        String?
  createdAt    DateTime @default(now())

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  stellarAccount   StellarAccount @relation("RecipientAccount", fields: [stellarAccountId], references: [id])
  stellarAccountId String         @unique

  safetyNets SafetyNet[]
}

enum SafetyNetStatus {
  ACTIVE // owner is checking in; money is theirs, family cannot claim yet
  OPENED // check-in window lapsed; family may now receive
  RECEIVED // family has received the money
  CLOSED // owner took the money back / cancelled
}

/// The core object: money set aside, guarded by a check-in.
model SafetyNet {
  id                 String          @id @default(cuid())
  kind               String          @default("SAFETY_NET") // SAFETY_NET | GIFT
  requestState       String          @default("NONE") // NONE | REQUESTED (family asked to open early)
  label              String
  amount             String // stored as string to preserve exact Stellar precision
  asset              String          @default("XLM")
  status             SafetyNetStatus @default(ACTIVE)
  balanceId          String? // current Stellar claimable balance id
  checkInIntervalMinutes Int         @default(43200) // default: about one month
  unlockAt           DateTime // date the net opens to family if no check-in
  lastCheckInAt      DateTime        @default(now())
  claimCode          String          @unique
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  // Money actions must sign with the wallet that set the money aside,
  // regardless of which wallet is currently active.
  wallet   Wallet @relation(fields: [walletId], references: [id])
  walletId String

  recipient   Recipient @relation(fields: [recipientId], references: [id])
  recipientId String

  activity Activity[]

  @@index([ownerId])
  @@index([ownerId, createdAt])
}

enum ActivityType {
  CREATED
  CHECKED_IN
  OPENED_TO_FAMILY
  RECEIVED
  CLOSED
}

/// Human-readable timeline for each safety net. Powers the demo story.
model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  description String
  txHash      String?
  createdAt   DateTime     @default(now())

  safetyNet   SafetyNet @relation(fields: [safetyNetId], references: [id], onDelete: Cascade)
  safetyNetId String

  @@index([safetyNetId, createdAt])
}

/// Runtime configuration & third-party credentials — kept in the DB, not in code.
model Setting {
  key   String @id
  value String
}

/// A savings goal ("Roof repair"). An earmark of funds the person is setting
/// aside toward a target — tracked here, spendable from the wallet as usual.
model Pot {
  id        String   @id @default(cuid())
  userId    String
  name      String
  target    String // amount as string
  saved     String   @default("0")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

/// Paluwagan (savings circle). Trimmed from PALUWAGAN.md for the MVP core:
/// contributions are paid member -> cycle recipient DIRECTLY (no pooled wallet),
/// so "payout" completes automatically when every contribution is in.
model PaluwaganGroup {
  id                 String    @id @default(cuid())
  name               String
  ownerId            String
  contributionAmount String
  frequencyMinutes   Int // 1 (testing) | 10080 weekly | 43200 monthly
  status             String    @default("DRAFT") // DRAFT | ACTIVE | COMPLETED | CANCELLED
  inviteCode         String    @unique
  currentCycle       Int       @default(0)
  startedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  members PaluwaganMember[]
  cycles  PaluwaganCycle[]

  @@index([ownerId])
}

model PaluwaganMember {
  id             String   @id @default(cuid())
  group          PaluwaganGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId        String
  userId         String
  name           String
  role           String   @default("MEMBER") // OWNER | MEMBER
  payoutPosition Int
  walletId       String // wallet used for paying & receiving
  joinedAt       DateTime @default(now())

  contributions PaluwaganContribution[]

  @@unique([groupId, userId])
  @@index([userId])
}

model PaluwaganCycle {
  id             String   @id @default(cuid())
  group          PaluwaganGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId        String
  cycleNumber    Int
  dueAt          DateTime
  payoutMemberId String
  status         String   @default("UPCOMING") // UPCOMING | COLLECTING | PAID_OUT

  contributions PaluwaganContribution[]

  @@unique([groupId, cycleNumber])
}

model PaluwaganContribution {
  id       String   @id @default(cuid())
  cycle    PaluwaganCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  cycleId  String
  member   PaluwaganMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId String
  amount   String
  status   String   @default("DUE") // DUE | PAID
  paidAt   DateTime?
  txHash   String?

  @@unique([cycleId, memberId])
}
