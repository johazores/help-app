// Sagip data model.
// Design note: Stellar account secrets are never stored in plaintext — each
// StellarAccount keeps an AES-256-GCM ciphertext plus its iv/tag. Network config
// and other credentials live in the Setting table, not in code (per brief).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A person who signs in to Sagip. Custodial: we hold their Stellar keys for them.
model User {
  id        String   @id @default(cuid())
  phone     String   @unique
  name      String
  pinHash          String
  email            String?   @unique
  emailVerifiedAt  DateTime?
  avatar           String? // small data-URL image, resized client-side
  activeWalletId   String? // which wallet money actions use
  createdAt        DateTime  @default(now())

  wallets    Wallet[]
  recipients Recipient[]
  safetyNets SafetyNet[]
  sessions   UserSession[]
  codes      VerificationCode[]
}

/// A signed-in device. Tokens carry the session id; revoking kills the token.
model UserSession {
  id         String    @id @default(cuid())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  device     String
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?

  @@index([userId])
}

/// Root admins: entirely separate identity, credentials, and sessions.
model AdminUser {
  id           String         @id @default(cuid())
  username     String         @unique
  email        String         @unique
  name         String
  passwordHash String
  createdAt    DateTime       @default(now())
  sessions     AdminSession[]
}

model AdminSession {
  id         String    @id @default(cuid())
  admin      AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  adminId    String
  device     String
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?

  @@index([adminId])
}

/// One-time codes for email verification and PIN recovery.
model VerificationCode {
  id         String    @id @default(cuid())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  identifier String // the email the code was sent to
  codeHash   String
  purpose    String // EMAIL_VERIFY | PIN_RESET
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?

  @@index([userId, purpose])
}

/// A custodial Stellar account. Secret is encrypted at rest.
model StellarAccount {
  id              String   @id @default(cuid())
  publicKey       String   @unique
  encryptedSecret String
  encryptionIv    String
  encryptionTag   String
  createdAt       DateTime @default(now())

  wallet    Wallet?
  recipient Recipient? @relation("RecipientAccount")
}

/// A named wallet a person owns. Custodial: keys live in StellarAccount,
/// encrypted. "Imported" wallets were brought in by the user's own secret key.
model Wallet {
  id        String   @id @default(cuid())
  name      String
  imported  Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  stellarAccount   StellarAccount @relation(fields: [stellarAccountId], references: [id])
  stellarAccountId String         @unique

  safetyNets SafetyNet[]

  @@index([userId])
}

/// A loved one the money can open to. Also custodial, so they can receive
/// without ever managing keys.
model Recipient {
  id           String   @id @default(cuid())
  name         String
  relationship String
  phone        String?
  createdAt    DateTime @default(now())

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  stellarAccount   StellarAccount @relation("RecipientAccount", fields: [stellarAccountId], references: [id])
  stellarAccountId String         @unique

  safetyNets SafetyNet[]
}

enum SafetyNetStatus {
  ACTIVE // owner is checking in; money is theirs, family cannot claim yet
  OPENED // check-in window lapsed; family may now receive
  RECEIVED // family has received the money
  CLOSED // owner took the money back / cancelled
}

/// The core object: money set aside, guarded by a check-in.
model SafetyNet {
  id                 String          @id @default(cuid())
  label              String
  amount             String // stored as string to preserve exact Stellar precision
  asset              String          @default("XLM")
  status             SafetyNetStatus @default(ACTIVE)
  balanceId          String? // current Stellar claimable balance id
  checkInIntervalMinutes Int         @default(43200) // default: about one month
  unlockAt           DateTime // date the net opens to family if no check-in
  lastCheckInAt      DateTime        @default(now())
  claimCode          String          @unique
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  // Money actions must sign with the wallet that set the money aside,
  // regardless of which wallet is currently active.
  wallet   Wallet @relation(fields: [walletId], references: [id])
  walletId String

  recipient   Recipient @relation(fields: [recipientId], references: [id])
  recipientId String

  activity Activity[]
}

enum ActivityType {
  CREATED
  CHECKED_IN
  OPENED_TO_FAMILY
  RECEIVED
  CLOSED
}

/// Human-readable timeline for each safety net. Powers the demo story.
model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  description String
  txHash      String?
  createdAt   DateTime     @default(now())

  safetyNet   SafetyNet @relation(fields: [safetyNetId], references: [id], onDelete: Cascade)
  safetyNetId String
}

/// Runtime configuration & third-party credentials — kept in the DB, not in code.
model Setting {
  key   String @id
  value String
}
