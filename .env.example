# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sagip?schema=public"

# Master key used to sign login tokens (any long random string).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_TOKEN_SECRET="change-me-to-a-long-random-string"

# 32-byte key (base64) used to encrypt Stellar account secrets at rest.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY="change-me-32-byte-base64-key"

# Optional: the mobile number that should have admin (ROOT) access.
# Sign up (or sign in) with this number and that account can see the admin panel.
ROOT_PHONE="09171234567"
