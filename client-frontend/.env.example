# =============================================================================
# Sagip — client-frontend (.env.example)
# Copy to .env.local (or .env) in this directory:
#   cp .env.example .env.local
#
# UI runs on http://localhost:8000
# All secrets (DB, JWT, Stellar, SMTP, …) live in server-backend/.env
# =============================================================================

# -----------------------------------------------------------------------------
# API proxy (proxy.ts)
# -----------------------------------------------------------------------------
# Backend origin for server-side /api rewrites. The browser never calls this
# URL directly — it uses same-origin /api/* so CORS is not needed in dev.
#
# Dev default (omit this line):  http://localhost:8001
# Production (required):         https://api.yourdomain.com
#
# API_URL="http://localhost:8001"
# API_URL="https://api.yourdomain.com"
