{
  "name": "server-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 8001",
    "build": "node scripts/clean-stale.js && npm run prisma:generate && npm run db:sync && next build",
    "start": "next start -p 8001",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "npm exec --yes --package=prisma@6.19.3 -- prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:sync": "node scripts/sync-database.mjs",
    "db:seed": "tsx prisma/seed.ts",
    "e2e": "tsx scripts/e2e-test.ts",
    "setup": "prisma migrate deploy && npm run prisma:generate && tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@stellar/stellar-sdk": "^13.1.0",
    "next": "^16.2.10",
    "nodemailer": "^9.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.2.10",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
